---
import type { Project } from '../data/types';

interface Props {
  projects: Project[];
  lang: 'es' | 'en';
}

const { projects, lang } = Astro.props;
const sectionTitle = lang === 'es' ? 'Proyectos' : 'Projects';
const techDescriptions: Record<string, string> = {
  'Laravel': 'PHP framework · MVC + Eloquent',
  'Laravel 12': 'PHP framework · última versión',
  'Filament': 'Admin panel para Laravel',
  'Filament v4': 'Admin panel · v4',
  'Inertia.js': 'SPA sin API · Laravel + Vue',
  'MySQL': 'Base de datos relacional',
  'REST API': 'API HTTP stateless · JSON',
};
const viewLabel = lang === 'es' ? 'Ver proyecto' : 'View project';
const internalLabel = lang === 'es' ? 'Sistema interno' : 'Internal system';
---

<section class="cv-section reveal">
  <div class="section-header">
    <span class="section-tag">05</span>
    <h2 class="section-title">{sectionTitle}</h2>
  </div>

  <div class="projects-grid">
    {projects.map((project) => (
      <article class="project-card">
        <div class="card-accent"></div>

        <div class="card-header">
          <div class="card-meta">
            <span class="card-year">{project.year}</span>
            <span class="meta-dot">·</span>
            <span class="card-client">{project.client}</span>
          </div>
          <h3 class="card-name">{project.name}</h3>
        </div>

        <p class="card-description">{project.description}</p>

        <div class="card-footer">
          <div class="card-stack">
            {project.stack.map((tech) => (
              <span class="tech-badge" title={techDescriptions[tech] || tech}>{tech}</span>
            ))}
          </div>
          {project.url ? (
            <a href={project.url} target="_blank" rel="noopener" class="card-link">
              {viewLabel}
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M7 17L17 7M17 7H7M17 7v10"/>
              </svg>
            </a>
          ) : (
            <span class="card-internal">{internalLabel}</span>
          )}
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .cv-section {
    max-width: 900px;
    margin: 0 auto;
    padding: 3.5rem 2rem;
    border-bottom: 1px solid var(--section-sep);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .section-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    color: var(--gold);
    letter-spacing: 0.12em;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.55rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 1rem;
  }

  .project-card {
    position: relative;
    overflow: hidden;
    background: var(--bg-card);
    border: 1px solid var(--border-card);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    position: relative;
    overflow: hidden;
    transition: border-color 0.22s, background 0.22s, transform 0.22s;
  }

  .card-accent {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--gold), transparent);
    opacity: 0.5;
    transition: opacity 0.22s;
  }

  .project-card:hover {
    transform: translateY(-6px);
    border-color: var(--gold-line);
    background: var(--bg-card-h);
    box-shadow: 0 12px 40px rgba(212,168,67,0.12), 0 2px 8px rgba(0,0,0,0.3);
  }

  .project-card:hover .card-accent { opacity: 1; }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.3rem;
  }

  .card-year {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    color: var(--gold);
    letter-spacing: 0.08em;
  }

  .meta-dot { color: var(--text-4); font-size: 0.7rem; }

  .card-client {
    font-size: 0.7rem;
    color: var(--text-3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .card-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
  }

  .card-description {
    font-size: 0.83rem;
    color: var(--text-2);
    line-height: 1.72;
    flex: 1;
  }

  .card-footer {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border);
    margin-top: auto;
  }

  .card-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .tech-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    padding: 0.18rem 0.45rem;
    background: var(--gold-dim);
    border: 1px solid var(--gold-line);
    color: var(--gold);
    border-radius: 2px;
    letter-spacing: 0.03em;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    color: var(--gold);
    text-decoration: none;
    font-weight: 500;
    letter-spacing: 0.04em;
    transition: gap 0.18s;
  }

  .card-link:hover { gap: 0.5rem; }

  .card-internal {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    color: var(--internal);
    letter-spacing: 0.06em;
  }
  .project-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .project-card:hover::before {
    opacity: 1;
  }

  /* Stack overlay al hover */
  .project-stack-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10,10,15,0.92);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    opacity: 0;
    transition: opacity 0.25s ease;
    padding: 1.5rem;
    backdrop-filter: blur(4px);
  }

  .project-card:hover .project-stack-overlay {
    opacity: 1;
  }

  .overlay-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.5rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    opacity: 0.7;
  }

  .overlay-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    justify-content: center;
  }

  .overlay-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    padding: 0.25rem 0.55rem;
    background: var(--gold-dim);
    border: 1px solid var(--gold-line);
    color: var(--gold);
  }


  @media (max-width: 640px) {
    .cv-section { padding: 2.5rem 1.25rem; }
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>