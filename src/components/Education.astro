---
import type { Education, Language } from '../data/types';

interface Props {
  education: Education[];
  languages: Language[];
  lang: 'es' | 'en';
}

const { education, languages, lang } = Astro.props;
const sectionTitle = lang === 'es' ? 'Educación' : 'Education';
const langTitle = lang === 'es' ? 'Idiomas' : 'Languages';
---

<section class="cv-section reveal">
  <div class="edu-lang-grid">
    <div>
      <div class="section-header">
        <span class="section-tag">02</span>
        <h2 class="section-title">{sectionTitle}</h2>
      </div>
      <div class="edu-list">
        {education.map((edu) => (
          <div class="edu-item">
            <div class="edu-period">
              <span>{edu.startDate}</span>
              <span class="period-sep">—</span>
              <span class="period-end">{edu.endDate}</span>
            </div>
            <h3 class="edu-degree">{edu.degree}</h3>
            <p class="edu-institution">{edu.institution}</p>
            <p class="edu-location">{edu.location}</p>
          </div>
        ))}
      </div>
    </div>

    <div>
      <div class="section-header">
        <span class="section-tag">04</span>
        <h2 class="section-title">{langTitle}</h2>
      </div>
      <div class="lang-list">
        {languages.map((l) => (
          <div class="lang-item">
            <span class="lang-name">{l.name}</span>
            <span class="lang-level">{l.level}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .cv-section {
    max-width: 900px;
    margin: 0 auto;
    padding: 3.5rem 2rem;
    border-bottom: 1px solid var(--section-sep);
  }

  .edu-lang-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .section-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: var(--gold);
    letter-spacing: 0.1em;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .edu-list { display: flex; flex-direction: column; gap: 1.5rem; }

  .edu-item {
    padding-left: 1rem;
    border-left: 2px solid var(--gold-line);
  }

  .edu-period {
    display: flex;
    gap: 0.35rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    color: var(--text-3);
    margin-bottom: 0.4rem;
  }

  .period-sep { color: var(--text-4); }
  .period-end { color: var(--gold); }

  .edu-degree {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.2rem;
  }

  .edu-institution {
    font-size: 0.82rem;
    color: var(--text-2);
    margin-bottom: 0.15rem;
  }

  .edu-location {
    font-size: 0.75rem;
    color: var(--text-3);
  }

  .lang-list { display: flex; flex-direction: column; gap: 0.85rem; }

  .lang-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.6rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border-card);
    border-radius: 2px;
  }

  .lang-name {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text);
  }

  .lang-level {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    color: var(--gold);
    letter-spacing: 0.05em;
  }

  @media (max-width: 640px) {
    .cv-section { padding: 2.5rem 1.25rem; }
    .edu-lang-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>