---
interface Props {
  title: string;
  lang: 'es' | 'en';
}
const { title, lang } = Astro.props;

const contactLabel = lang === 'es' ? 'Contacto' : 'Contact';
const expLabel = lang === 'es' ? 'experiencia activa' : 'active experience';
const yearU = lang === 'es' ? 'a' : 'y';
const weekU = lang === 'es' ? 's' : 'w';
---

<!DOCTYPE html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>

    <!-- Open Graph / Social Preview -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Mauricio Cruz — Desarrollador Full Stack" />
    <meta property="og:description" content="Full Stack Developer especializado en Laravel, Clean Architecture y DDD. 4+ años construyendo sistemas reales en producción." />
    <meta property="og:url" content="https://olympohn.com" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Mauricio Cruz — Full Stack Developer" />
    <meta name="twitter:description" content="Full Stack Developer · Laravel · Clean Architecture · DDD · 4+ años de experiencia." />
    <meta name="description" content="CV de Mauricio Cruz, Desarrollador Full Stack con experiencia en Laravel, Clean Architecture, DDD, CI/CD y sistemas en producción." />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <style>
      [data-theme="dark"] {
        --bg:          #0A0A0F;
        --bg-2:        #12121A;
        --bg-card:     rgba(255,255,255,0.025);
        --bg-card-h:   rgba(212,168,67,0.04);
        --border:      rgba(255,255,255,0.06);
        --border-card: rgba(255,255,255,0.07);
        --border-h:    rgba(212,168,67,0.22);
        --text:        #FAFAF7;
        --text-2:      #94A3B8;
        --text-3:      #64748B;
        --text-4:      #2A2A3D;
        --gold:        #D4A843;
        --gold-dim:    rgba(212,168,67,0.12);
        --gold-line:   rgba(212,168,67,0.28);
        --gold-glow:   rgba(212,168,67,0.06);
        --dot-border:  #0A0A0F;
        --summary-bg:  rgba(212,168,67,0.04);
        --section-sep: rgba(255,255,255,0.05);
        --nav-bg:      rgba(10,10,15,0.88);
        --scrollbar:   #12121A;
        --internal:    #2A2A3D;
        --cursor-color:#D4A843;
      }

      [data-theme="light"] {
        --bg:          #F5F3EE;
        --bg-2:        #EDEAE2;
        --bg-card:     rgba(255,255,255,0.7);
        --bg-card-h:   rgba(255,255,255,0.95);
        --border:      rgba(0,0,0,0.07);
        --border-card: rgba(0,0,0,0.08);
        --border-h:    rgba(184,146,46,0.35);
        --text:        #0A0A0F;
        --text-2:      #3D4A5C;
        --text-3:      #64748B;
        --text-4:      #C8C0B0;
        --gold:        #B8922E;
        --gold-dim:    rgba(184,146,46,0.1);
        --gold-line:   rgba(184,146,46,0.3);
        --gold-glow:   rgba(184,146,46,0.06);
        --dot-border:  #F5F3EE;
        --summary-bg:  rgba(184,146,46,0.05);
        --section-sep: rgba(0,0,0,0.06);
        --nav-bg:      rgba(245,243,238,0.9);
        --scrollbar:   #EDEAE2;
        --internal:    #C8C0B0;
        --cursor-color:#B8922E;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }

      body {
        font-family: 'DM Sans', sans-serif;
        background-color: var(--bg);
        color: var(--text);
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
        transition: background-color 0.35s ease, color 0.35s ease;
      }

      *, *::before, *::after {
        transition: background-color 0.35s ease, border-color 0.35s ease, color 0.35s ease;
      }

      ::selection { background: var(--gold); color: #0A0A0F; }
      ::-webkit-scrollbar { width: 3px; }
      ::-webkit-scrollbar-track { background: var(--scrollbar); }
      ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 2px; }

      /* ── ANIMACIONES DE ENTRADA ── */
      .reveal {
        opacity: 0;
        transform: translateY(22px);
        transition: opacity 0.55s ease, transform 0.55s ease;
      }

      .reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }

      .reveal-delay-1 { transition-delay: 0.1s; }
      .reveal-delay-2 { transition-delay: 0.2s; }
      .reveal-delay-3 { transition-delay: 0.3s; }

      /* ── CONTADOR FLOTANTE IZQUIERDA ── */
      .exp-clock {
        position: fixed;
        bottom: 1.5rem;
        left: 1.5rem;
        z-index: 50;
        background: var(--bg-2);
        border: 1px solid var(--gold-line);
        padding: 0.55rem 0.85rem;
        display: flex;
        flex-direction: column;
        gap: 0.28rem;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        box-shadow: 0 4px 24px rgba(0,0,0,0.2);
        transition: transform 0.3s, box-shadow 0.3s;
      }

      .exp-clock::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--gold), transparent);
      }

      .exp-clock:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,0.3); }

      .clock-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.45rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--gold);
        opacity: 0.7;
        text-align: center;
      }

      .clock-display { display: flex; align-items: baseline; gap: 0.12rem; }
      .clock-unit { display: flex; align-items: baseline; gap: 0.04rem; }

      .clock-num {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.78rem;
        font-weight: 500;
        color: var(--text);
        letter-spacing: -0.02em;
        min-width: 1.5ch;
        text-align: center;
      }

      .clock-unit--sec .clock-num { color: var(--gold); }
      .clock-u { font-family: 'JetBrains Mono', monospace; font-size: 0.4rem; color: var(--text-3); }
      .clock-sep { font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; color: var(--gold); opacity: 0.22; padding: 0 0.04rem; }

      /* ── BOTÓN CONTACTO DERECHA ── */
      .contact-fab { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 50; }

      .contact-fab-btn {
        width: 46px; height: 46px;
        border-radius: 50%;
        background: #25D366;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 20px rgba(37,211,102,0.35);
        transition: transform 0.25s, box-shadow 0.25s;
        position: relative;
        z-index: 2;
      }

      .contact-fab-btn:hover { transform: scale(1.08); box-shadow: 0 6px 28px rgba(37,211,102,0.5); }
      .contact-fab-btn svg { width: 22px; height: 22px; }

      .contact-panel {
        position: absolute;
        bottom: 56px; right: 0;
        width: 230px;
        background: var(--bg-2);
        border: 1px solid var(--border-card);
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(0,0,0,0.25);
        opacity: 0;
        transform: translateY(10px) scale(0.97);
        pointer-events: none;
        transition: opacity 0.25s ease, transform 0.25s ease;
      }

      .contact-panel::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 2px;
        background: linear-gradient(90deg, #25D366, var(--gold));
      }

      .contact-panel.open { opacity: 1; transform: translateY(0) scale(1); pointer-events: all; }

      .contact-panel-title {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.55rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--text-3);
        padding: 0.75rem 1rem 0.5rem;
      }

      .contact-link {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.65rem 1rem;
        text-decoration: none;
        color: var(--text-2);
        font-size: 0.82rem;
        border-top: 1px solid var(--border);
        transition: background 0.15s, color 0.15s, padding-left 0.15s;
      }

      .contact-link:hover { background: var(--gold-dim); color: var(--text); padding-left: 1.25rem; }
      .contact-link-icon { width: 16px; height: 16px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
      .contact-link-icon svg { width: 16px; height: 16px; }

      .fab-pulse {
        position: absolute; inset: 0;
        border-radius: 50%;
        background: rgba(37,211,102,0.4);
        animation: pulse 2.5s ease-out infinite;
        pointer-events: none;
      }

      @keyframes pulse {
        0%   { transform: scale(1); opacity: 0.6; }
        70%  { transform: scale(1.6); opacity: 0; }
        100% { transform: scale(1.6); opacity: 0; }
      }

      /* ── TOOLTIP COPIADO ── */
      .copy-toast {
        position: fixed;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%) translateY(10px);
        background: var(--bg-2);
        border: 1px solid var(--gold-line);
        color: var(--gold);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.72rem;
        letter-spacing: 0.1em;
        padding: 0.5rem 1rem;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s ease, transform 0.2s ease;
        z-index: 200;
      }

      .copy-toast.show {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
      }

      /* ── FOOTER ── */
      .cv-footer {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 2rem 3rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .footer-copy {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.62rem;
        color: var(--text-3);
        letter-spacing: 0.08em;
      }

      .footer-cta {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1.1rem;
        background: rgba(37,211,102,0.08);
        border: 1px solid rgba(37,211,102,0.25);
        color: #25D366;
        font-size: 0.8rem;
        font-weight: 500;
        text-decoration: none;
        letter-spacing: 0.03em;
        transition: all 0.2s;
      }

      .footer-cta:hover { background: rgba(37,211,102,0.15); border-color: #25D366; transform: translateY(-1px); }
      .footer-cta svg { width: 14px; height: 14px; }


      /* ── Stats dentro del widget ── */
      .clock-stats {
        border-top: 1px solid var(--gold-line);
        margin-top: 0.3rem;
        padding-top: 0.35rem;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.25rem 0.5rem;
      }

      .clock-stat {
        display: flex;
        align-items: baseline;
        gap: 0.1rem;
      }

      .clock-stat-num {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.72rem;
        font-weight: 500;
        color: var(--gold);
        min-width: 1.4ch;
      }

      .clock-stat-plus {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.5rem;
        color: var(--gold);
        opacity: 0.6;
      }

      .clock-stat-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.38rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--text-3);
        margin-left: 0.15rem;
      }


      /* ── SKELETON LOADER ── */
      .skeleton-screen {
        position: fixed;
        inset: 0;
        z-index: 999;
        background: var(--bg);
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        transition: opacity 0.4s ease, visibility 0.4s ease;
      }

      .skeleton-screen.hidden {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
      }

      .sk-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: 900px;
        margin: 0 auto;
        width: 100%;
        padding: 0.5rem 0;
      }

      .sk-block {
        background: linear-gradient(
          90deg,
          var(--bg-2) 25%,
          rgba(212,168,67,0.06) 50%,
          var(--bg-2) 75%
        );
        background-size: 200% 100%;
        animation: shimmer 1.6s infinite;
        border-radius: 2px;
      }

      @keyframes shimmer {
        0%   { background-position: 200% 0; }
        100% { background-position: -200% 0; }
      }

      .sk-hero {
        max-width: 900px;
        margin: 1rem auto 0;
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }

      .sk-title   { height: 72px; width: 55%; }
      .sk-sub     { height: 14px; width: 22%; margin-top: 0.25rem; }
      .sk-divider { height: 1px;  width: 100%; opacity: 0.4; margin: 0.5rem 0; }
      .sk-para    { height: 80px; width: 75%; }
      .sk-section { height: 20px; width: 18%; margin-top: 0.5rem; }
      .sk-card    { height: 120px; width: 100%; margin-top: 0.25rem; }
      .sk-logo    { height: 20px; width: 40px; }
      .sk-btns    { display: flex; gap: 0.75rem; }
      .sk-btn     { height: 32px; width: 100px; }
      .sk-btn-sm  { height: 32px; width: 60px; }

      /* ── TRANSICIÓN IDIOMA ── */
      body.lang-switching {
        opacity: 0;
        transition: opacity 0.25s ease;
      }

      @media (max-width: 640px) {
        .exp-clock { bottom: 1rem; left: 1rem; padding: 0.45rem 0.65rem; }
        .clock-num { font-size: 0.68rem; }
        .contact-fab { bottom: 1rem; right: 1rem; }
        .cv-footer { padding: 1.5rem 1.25rem 2.5rem; }
      }

    </style>
  </head>
  <body>


    <!-- Skeleton loader -->
    <div class="skeleton-screen" id="skeleton-screen">
      <div class="sk-nav">
        <div class="sk-block sk-logo"></div>
        <div class="sk-btns">
          <div class="sk-block sk-btn-sm"></div>
          <div class="sk-block sk-btn-sm"></div>
          <div class="sk-block sk-btn"></div>
        </div>
      </div>
      <div class="sk-hero">
        <div class="sk-block sk-sub"></div>
        <div class="sk-block sk-title"></div>
        <div class="sk-block sk-sub" style="width:18%"></div>
        <div class="sk-block sk-divider"></div>
        <div class="sk-block sk-para"></div>
        <div class="sk-block sk-section"></div>
        <div class="sk-block sk-card"></div>
        <div class="sk-block sk-section"></div>
        <div class="sk-block sk-card" style="height:80px"></div>
      </div>
    </div>

    <!-- Toast copiado -->
    <div class="copy-toast" id="copy-toast">
      {lang === 'es' ? '✓ Email copiado' : '✓ Email copied'}
    </div>
    <slot />

    <!-- Footer -->
    <footer class="cv-footer reveal">
      <span class="footer-copy">
        © <span id="footer-year">2026</span> Mauricio Cruz · {lang === 'es' ? 'Todos los derechos reservados' : 'All rights reserved'}
      </span>
      <a href="https://wa.me/50433012826" target="_blank" rel="noopener" class="footer-cta">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
        {lang === 'es' ? '¿Hablamos?' : "Let's talk"}
      </a>
    </footer>

    <!-- Contador flotante izquierda -->
    <div class="exp-clock">
      <div class="clock-label">{expLabel}</div>
      <div class="clock-display">
        <div class="clock-unit"><span class="clock-num" id="f-years">00</span><span class="clock-u">{yearU}</span></div>
        <span class="clock-sep">:</span>
        <div class="clock-unit"><span class="clock-num" id="f-months">00</span><span class="clock-u">m</span></div>
        <span class="clock-sep">:</span>
        <div class="clock-unit"><span class="clock-num" id="f-weeks">00</span><span class="clock-u">{weekU}</span></div>
        <span class="clock-sep">:</span>
        <div class="clock-unit"><span class="clock-num" id="f-days">00</span><span class="clock-u">d</span></div>
        <span class="clock-sep">:</span>
        <div class="clock-unit"><span class="clock-num" id="f-hours">00</span><span class="clock-u">h</span></div>
        <span class="clock-sep">:</span>
        <div class="clock-unit"><span class="clock-num" id="f-minutes">00</span><span class="clock-u">m</span></div>
        <span class="clock-sep">:</span>
        <div class="clock-unit clock-unit--sec"><span class="clock-num" id="f-seconds">00</span><span class="clock-u">s</span></div>
      </div>

      <div class="clock-stats">
        <div class="clock-stat">
          <span class="clock-stat-num" id="s-years">4</span>
          <span class="clock-stat-plus">+</span>
          <span class="clock-stat-label">{lang === 'es' ? 'años' : 'years'}</span>
        </div>
        <div class="clock-stat">
          <span class="clock-stat-num" id="s-projects">12</span>
          <span class="clock-stat-label">{lang === 'es' ? 'proyectos' : 'projects'}</span>
        </div>
        <div class="clock-stat">
          <span class="clock-stat-num" id="s-tech">15</span>
          <span class="clock-stat-plus">+</span>
          <span class="clock-stat-label">{lang === 'es' ? 'tecnol.' : 'techs'}</span>
        </div>
        <div class="clock-stat">
          <span class="clock-stat-num" id="s-langs">3</span>
          <span class="clock-stat-label">{lang === 'es' ? 'idiomas' : 'langs'}</span>
        </div>
      </div>
    </div>

    <!-- Botón contacto derecha -->
    <div class="contact-fab">
      <div class="contact-panel" id="contact-panel">
        <div class="contact-panel-title">{contactLabel}</div>
        <a href="https://wa.me/50433012826" target="_blank" rel="noopener" class="contact-link">
          <span class="contact-link-icon"><svg viewBox="0 0 24 24" fill="#25D366"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg></span>
          WhatsApp
        </a>
        <a href="mailto:olympocruz@gmail.com" class="contact-link" id="copy-email-link">
          <span class="contact-link-icon"><svg viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.8"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg></span>
          olympocruz@gmail.com
        </a>
        <a href="https://www.linkedin.com/in/mauricio-cruz-garcia-939b61370" target="_blank" rel="noopener" class="contact-link">
          <span class="contact-link-icon"><svg viewBox="0 0 24 24" fill="#0A66C2"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></span>
          LinkedIn
        </a>
        <a href="https://olympohn.com" target="_blank" rel="noopener" class="contact-link">
          <span class="contact-link-icon"><svg viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></span>
          olympohn.com
